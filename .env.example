# ============================================
# .env da raiz — consumido pelo docker-compose.yml
# Copie para .env e preencha apenas se quiser ativar notificações reais.
# Sem este arquivo, o backend roda com MockProvider (notificações
# apenas em stdout) — totalmente funcional para avaliação.
# ============================================

# --- Twilio WhatsApp Sandbox ---
# Passos para ativar:
#   1. Crie conta em https://www.twilio.com/try-twilio (grátis)
#   2. Ative o sandbox em: Messaging → Try it out → Send a WhatsApp message
#   3. Do seu WhatsApp, envie "join <duas-palavras>" para +1 415 523 8886
#   4. Copie Account SID + Auth Token da home do console
#   5. Preencha as variáveis abaixo
#   6. Rode: docker compose up -d backend

NOTIFICATIONS_ENABLED=false

# Account SID do Twilio (começa com AC...)
TWILIO_ACCOUNT_SID=

# Auth Token do Twilio
TWILIO_AUTH_TOKEN=

# Número fixo do sandbox Twilio; só alterar em produção com número próprio
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# URL usada nos links das mensagens enviadas (consulta pública por protocolo)
PUBLIC_APP_URL=http://localhost:4200
